{
	"$schema": "https://json.schemastore.org/tsconfig",

	"compilerOptions": {
		"allowImportingTsExtensions": false,

		"baseUrl": "./",

		"emitDecoratorMetadata": true,

		"experimentalDecorators": true,

		"lib": ["ESNext", "DOM", "DOM.Iterable"],

		"module": "ESNext",

		"moduleResolution": "Bundler",

		"outDir": "Target",

		"plugins": [
			{
				"allowedDuplicatedPackages": [],

				"completions": true,

				"diagnosticSeverity": {
					"duplicatePackage": "error",

					"floatingEffect": "error",

					"leakingRequirements": "error",

					"missingEffectContext": "error",

					"missingEffectError": "error",

					"missingReturnYieldStar": "error",

					"missingStarInYieldEffectGen": "error",

					"unnecessaryEffectGen": "error",

					"unnecessaryPipe": "error"
				},

				"diagnostics": true,

				"name": "@effect/language-service",

				"quickinfo": true,

				"transform": "@effect/language-service/transform"
			}
		],

		"rootDirs": ["."],

		"target": "ESNext"
	},

	"exclude": ["Target", "node_modules"],

	// "extends": "@playform/build/tsconfig", // Commented out - package not available

	"include": ["Source/Skeleton.ts", "@types/node"]
}
