# Build output
/Target/
/Configuration/

# Generated files (regenerated by codegen)
/Source/Generated/

# Compiled .js copies of authored .ts files — the .ts is canonical
Source/ESBuild.js

# Node.js
node_modules/

# Editor / OS files
*.backup
.DS_Store
Thumbs.db
