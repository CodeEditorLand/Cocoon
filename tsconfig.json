{
	"$schema": "https://json.schemastore.org/tsconfig",

	"compilerOptions": {
		"baseUrl": "./",

		"composite": true,

		"declarationMap": true,

		"emitDeclarationOnly": true,

		"emitDecoratorMetadata": true,

		"experimentalDecorators": true,

		"lib": ["ESNext", "DOM", "DOM.Iterable"],

		"module": "ESNext",

		"moduleResolution": "Bundler",

		"outDir": "Target",

		"paths": {
			"@codeeditorland/output/*": ["../Output/Target/Microsoft/VSCode/*"]
		},

		"plugins": [
			{
				"allowedDuplicatedPackages": [],

				"completions": true,

				"diagnosticSeverity": {
					"duplicatePackage": "error",

					"floatingEffect": "error",

					"leakingRequirements": "error",

					"missingEffectContext": "error",

					"missingEffectError": "error",

					"missingReturnYieldStar": "error",

					"missingStarInYieldEffectGen": "error",

					"unnecessaryEffectGen": "error",

					"unnecessaryPipe": "error"
				},

				"diagnostics": true,

				"name": "@effect/language-service",

				"quickinfo": true,

				"transform": "@effect/language-service/transform"
			}
		],

		"rootDir": ".",

		"target": "ESNext"
	},

	"exclude": ["Target", "node_modules"],

	"extends": "@playform/build/tsconfig",

	"include": ["Source", "@types/node"]
}
