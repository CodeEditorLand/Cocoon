{
	"$schema": "https://json.schemastore.org/tsconfig",

	"compilerOptions": {
		"baseUrl": "./",

		"emitDeclarationOnly": false,

		"emitDecoratorMetadata": true,

		"experimentalDecorators": true,

		"module": "ESNext",

		"moduleResolution": "Bundler",

		"noEmit": true,

		"outDir": "Target",

		"paths": {
			"vs/*": ["../../Dependency/Microsoft/Dependency/Editor/src/vs/*"]
		},

		"rootDirs": [".", "../../Dependency/Microsoft/Dependency/Editor/src/"],

		"target": "ESNext",

		// vs/compatbile
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"verbatimModuleSyntax": false,
		"strict": false,
		"exactOptionalPropertyTypes": false,
		"noUncheckedIndexedAccess": false,
		"skipLibCheck": true,
		"isolatedModules": false,

		"plugins": [
			{
				"name": "@effect/language-service",
				"transform": "@effect/language-service/transform",
				"diagnostics": true, // controls Effect diagnostics (default: true)
				"diagnosticSeverity": {
					// allows to change per-rule default severity of the diagnostic in the whole project
					"floatingEffect": "warning" // example for a rule, allowed values are off,error,warning,message,suggestion,
				},
				"quickinfo": true, // controls quickinfo over Effect (default: true)
				"completions": true, // controls Effect completions (default: true)
				"allowedDuplicatedPackages": [] // list of package names that has effect in peer dependencies and are allowed to be duplicated (default: [])
			}
		]
	},

	"exclude": ["Target"],

	"extends": "@playform/build/tsconfig",

	"include": [
		"Source",
		"@types/node",

		"../../Dependency/Microsoft/Dependency/Editor/src/*.ts",
		"../../Dependency/Microsoft/Dependency/Editor/src/typings",
		"../../Dependency/Microsoft/Dependency/Editor/src/vs/**/*.ts",
		"../../Dependency/Microsoft/Dependency/Editor/src/vscode-dts/vscode.proposed.*.d.ts",
		"../../Dependency/Microsoft/Dependency/Editor/src/vscode-dts/vscode.d.ts"
	]
}
